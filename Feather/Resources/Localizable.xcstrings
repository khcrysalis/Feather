        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Introduzca la contraseña asociada a la llave privada, déjalo en blanco si una contraseña no es necesaria."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
