    "Default:\nSigns an application with your specified certificate.\n\nAdhoc (Advanced):\nSigns with no identity, however this unfortunately strips entitlements (iOS won't install this type)." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Standard:\nSigniert eine App mit deiner spezifizierten Zertifikat.\n\nAdhoc (Erweitert):\nSigniert ohne Identität, dadurch werden leider Entitlements entfernt (iOS würde diese nicht installieren)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Default:\nSigns an application with your specified certificate.\n\nAdhoc (Advanced):\nSigns with no identity, however this unfortunately strips entitlements (iOS won't install this type)."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Domyślnie:\nPodpisuje aplikację wskazanym certyfikatem.\n\nAdhoc (Zaawansowane):\nPodpisuje bez tożsamości, jednak usuwa uprawnienia (iOS nie zainstaluje takiego typu)."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mặc định:\nKý một ứng dụng bằng chứng chỉ do bạn chỉ định.\n\nAdhoc (Nâng cao):\nKý mà không cần danh tính, tuy nhiên điều này không may sẽ xóa bỏ các quyền (iOS sẽ không cài đặt loại này)."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Default:Firma un'app con il tuo certificato specificato.Adhoc (Avanzato):Firma senza identità, tuttavia, questo purtroppo rimuove i diritti (iOS non installerà questo tipo)."
          }
        }
      }
    },
